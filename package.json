{
  "name": "triggerix-editor-vue",
  "type": "module",
  "version": "0.0.6",
  "packageManager": "pnpm@11.6.0",
  "description": "Vue composables and utilities for Triggerix editor",
  "homepage": "https://github.com/triggerix-lang/triggerix-editor-vue#readme",
  "repository": {
    "type": "git",
    "url": "git@github.com:triggerix-lang/triggerix-editor-vue.git"
  },
  "bugs": {
    "url": "https://github.com/triggerix-lang/triggerix-editor-vue/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint --cache",
    "release": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@triggerix/editor": "^0.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vue": "^3.5.38"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
